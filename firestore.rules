rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function getRole() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }
    function isMechanic() {
      return isSignedIn() && getRole() in ['admin', 'mechanic'];
    }

    // ── Profiles ─────────────────────────────────────────────
    match /profiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Vehicles ─────────────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow read: if isAdmin();
    }

    // ── Bookings ─────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow create: if true;   // guests can book
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) || isMechanic()
      );
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) || isMechanic()
      );
      allow delete: if isAdmin();
    }

    // ── Available Slots ───────────────────────────────────────
    match /slots/{slotId} {
      allow read: if true;          // public
      allow write: if isAdmin();
    }

    // ── Estimates ─────────────────────────────────────────────
    match /estimates/{estimateId} {
      allow create: if true;        // guests can request
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow update, delete: if isAdmin();
    }
  }
}
